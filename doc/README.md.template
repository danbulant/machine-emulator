ln -sf "$RECIPES_DIR/run-rolling-calculator.lua" .
{
# docs:begin server
cartesi-jsonrpc-machine \
    --server-address=127.0.0.1:8085
# docs:end server
} > server 2>&1 &
srv_pid=$!
while ! cartesi-machine --remote-address=127.0.0.1:8085 --remote-health-check 2>/dev/null; do sleep 1; done
{
