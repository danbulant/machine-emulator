local cartesi = require "cartesi"
for _, n in ipairs({"PMA_EMPTY_DID", "PMA_MEMORY_DID", "PMA_SHADOW_STATE_DID",
        "PMA_FLASH_DRIVE_DID", "PMA_CLINT_DID", "PMA_HTIF_DID", "PMA_PLIC_DID",
